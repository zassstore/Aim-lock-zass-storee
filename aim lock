-- SISTEM CHAMS (OUTLINE TEBAL + 15% FILL) 😈
local function CreateVisuals(plr)
    local Highlight = Instance.new("Highlight")
    Highlight.Name = "X_Premium_Chams"
    Highlight.FillColor = Color3.fromRGB(255, 255, 255)
    Highlight.FillTransparency = 0.85 
    Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    Highlight.OutlineTransparency = 0 
    Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    Highlight.Enabled = false

    local Tracer = Drawing.new("Line"); Tracer.Visible = false; Tracer.Color = Color3.fromRGB(255, 255, 255); Tracer.Thickness = 1.5
    local Name = Drawing.new("Text"); Name.Visible = false; Name.Color = Color3.fromRGB(255, 255, 255); Name.Size = 14; Name.Center = true; Name.Outline = true

    RunService.RenderStepped:Connect(function()
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr ~= Player and plr.Character.Humanoid.Health > 0 then
            local hrp = plr.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            
            if _SETTINGS.ChamsEnabled then
                Highlight.Parent = plr.Character
                Highlight.Enabled = true
            else
                Highlight.Enabled = false
            end

            if onScreen then
                Tracer.Visible = _SETTINGS.EspLines; Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); Tracer.To = Vector2.new(pos.X, pos.Y)
                Name.Visible = _SETTINGS.EspNames; Name.Position = Vector2.new(pos.X, pos.Y - 45); Name.Text = plr.Name
            else Tracer.Visible = false; Name.Visible = false end
        else Highlight.Enabled = false; Tracer.Visible = false; Name.Visible = false end
    end)
end

for _, v in pairs(game.Players:GetPlayers()) do if v ~= Player then CreateVisuals(v) end end
game.Players.PlayerAdded:Connect(function(v) CreateVisuals(v) end)

-- AIM LOCK SYSTEM 😈
RunService.RenderStepped:Connect(function()
    if _SETTINGS.Enabled then
        local target = nil; local dist = _SETTINGS.FovSize
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= Player and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(v.Character.Head.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if d < dist then dist = d; target = v.Character end
                end
            end
        end
        if target then Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Head.Position) * CFrame.Angles(math.rad(_SETTINGS.TiltVertical), 0, 0) end
    end
end)
